<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main" android:layout_width="match_parent" android:layout_height="match_parent" tools:context=".MainActivity">
    <!--  Toast Button  -->
    <Button android:id="@+id/button_toast" android:layout_width="120dp" android:layout_height="wrap_content" android:text="Toast" android:onClick="show_toast" app:layout_constraintTop_toTopOf="@+id/text_display_count" app:layout_constraintBottom_toTopOf="@+id/button_zero" app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="16dp"/>
    <!--  Zero Button  -->
    <Button android:id="@+id/button_zero" android:layout_width="120dp" android:layout_height="wrap_content" android:text="Zero" android:onClick="showZero" android:backgroundTint="@android:color/darker_gray" app:layout_constraintTop_toBottomOf="@id/button_toast" app:layout_constraintBottom_toTopOf="@id/button_count" app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="16dp"/>
    <!--  Count Button  -->
    <Button android:id="@+id/button_count" android:layout_width="120dp" android:layout_height="wrap_content" android:text="Count" android:onClick="increase_count" app:layout_constraintTop_toBottomOf="@id/button_zero" app:layout_constraintBottom_toBottomOf="@+id/text_display_count" app:layout_constraintStart_toStartOf="parent" android:layout_marginStart="16dp"/>
    <!--  Counter Text  -->
    <TextView android:id="@+id/text_display_count" android:layout_width="0dp" android:layout_height="0dp" android:layout_margin="16dp" android:background="@android:color/holo_orange_light" android:gravity="center" android:text="0" android:textColor="#673AB7" android:textSize="120sp" android:textStyle="bold" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/button_toast" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>